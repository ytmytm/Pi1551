# To show build commands: make V=1
ifneq ($(V),1)
Q		:= @
endif

# Pi1551 supports Raspberry Pi 3 family boards only (3A/3A+/3B/3B+).
# Keep RASPPI overridable for tooling compatibility, but reject all non-3
# targets so accidental Pi1541-era builds fail loudly.
RASPPI	?= 3
PREFIX	?= arm-none-eabi-

CC	= $(PREFIX)gcc
CPP	= $(PREFIX)g++
AS	= $(CC)
LD	= $(PREFIX)ld
AR	= $(PREFIX)ar

ifeq ($(strip $(RASPPI)),3)
	ARCH	?= -march=armv8-a+crc -mtune=cortex-a53 -mfpu=crypto-neon-fp-armv8 -mfloat-abi=hard -marm -mno-unaligned-access -DRPI3=1
	CFLAGS	+= -DRPI3=1
else
$(error Pi1551 supports Raspberry Pi 3 family boards only; build with RASPPI=3)
endif

AFLAGS	 += $(ARCH)
CFLAGS	 += $(ARCH) -Wall -Wno-unused-variable -Wno-unused-but-set-variable -Wno-psabi -fsigned-char -fno-builtin -Ofast -DNDEBUG
CPPFLAGS := $(CFLAGS) $(CPPFLAGS) -fno-exceptions -fno-rtti -std=c++0x -Wno-write-strings
CFLAGS	 += -fno-delete-null-pointer-checks -fdata-sections -ffunction-sections -u _printf_float -std=gnu99

.PHONY: clean

%.o: %.S
	@echo "  AS   $@"
	$(Q)$(AS) $(AFLAGS) $(INCLUDE) -c -o $@ $<

%.o: %.c
	@echo "  CC   $@"
	$(Q)$(CC) $(CFLAGS) $(INCLUDE) -c -o $@ $<

%.o: %.cpp
	@echo "  CPP  $@"
	$(Q)$(CPP) $(CPPFLAGS) $(INCLUDE) -c -o $@ $<
